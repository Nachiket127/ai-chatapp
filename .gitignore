# Node
node_modules/
**/node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Build output
dist/
Frontend/dist/
Frontend/.vite/
build/
coverage/

# Env files (keep secrets out of VCS)
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Render / deployment files that may contain secrets
render.yaml

# OS files
.DS_Store
Thumbs.db

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Keys and certificates
*.pem
*.key
*.crt

# Misc
.cache/
*.envrc
*.local

# Socket files
*.sock

# Temporary
tmp/
temp/

# Ignore dotenv expose files
.envrc

# Optional: lockfiles if you don't want them tracked
# package-lock.json
# pnpm-lock.yaml
# yarn.lock
